# Sorftime upstream secret. Production should prefer a mounted secret file.
# Never commit a real Account-SK.
SORFTIME_ACCOUNT_SK=
# SORFTIME_ACCOUNT_SK_FILE=/run/secrets/sorftime_account_sk
SORFTIME_BASE_URL=https://standardapi.sorftime.com/api/
SORFTIME_MCP_TIMEOUT_MS=60000
SORFTIME_MCP_MAX_RESPONSE_BYTES=5000000

# Streamable HTTP service
NODE_ENV=development
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000

# disabled is permitted only for local development. Shared deployments must use
# api_key or trusted_headers (behind a company identity gateway).
MCP_AUTH_MODE=disabled
# Per-user records; use a Secret Manager in production. Keys must be >=32 chars.
MCP_API_KEYS_JSON=[]
# Example shape only:
# MCP_API_KEYS_JSON=[{"key":"replace-with-secret","subject":"alice@example.com","tenant":"team","role":"reader"}]

# For an identity-aware reverse proxy. The proxy must authenticate employees,
# inject trusted headers, and prove itself with this separate secret.
MCP_TRUSTED_PROXY_SECRET=

MCP_ALLOWED_ORIGINS=
MCP_ALLOWED_HOSTS=
MCP_MAX_CONCURRENT_REQUESTS=20
MCP_MAX_SESSIONS=100
MCP_SESSION_TTL_MS=1800000
MCP_RATE_LIMIT_PER_MINUTE=30
MCP_GLOBAL_RATE_LIMIT_PER_MINUTE=300
MCP_AUDIT_LOG_PATH=var/audit.jsonl

# Admin tools remain free + read-only and are disabled by default.
MCP_ENABLE_ADMIN_TOOLS=false

# Stdio has no employee login. Bind one identity at process launch.
MCP_STDIO_SUBJECT=local-operator
MCP_STDIO_TENANT=local
MCP_STDIO_ROLE=reader

# CLI-only default
SORFTIME_DOMAIN=us
