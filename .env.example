# Server-side Sorftime Account-SK. Do not commit a real key.
SORFTIME_API_KEY=

# JWT settings for colleague MCP access tokens.
SORFTIME_MCP_JWT_SECRET=replace-with-a-long-random-secret
SORFTIME_MCP_ISSUER=sorftime-mcp
SORFTIME_MCP_AUDIENCE=sorftime-mcp-users

# Optional runtime settings.
SORFTIME_API_BASE_URL=https://standardapi.sorftime.com/api
SORFTIME_API_TIMEOUT_SECONDS=120
SORFTIME_API_MAX_RETRIES=3
SORFTIME_API_RETRY_BASE_DELAY_SECONDS=2
SORFTIME_API_RETRY_MAX_DELAY_SECONDS=15
SORFTIME_AUDIT_LOG_PATH=
